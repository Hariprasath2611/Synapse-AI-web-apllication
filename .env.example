# Synapse AI — Configuration Environment Variables
PORT=5000
NODE_ENV=development

# Gemini API Key (Required for live AI responses)
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB Connection (Falls back to local file storage if empty)
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/synapse_ai?retryWrites=true&w=majority

# JWT Secrets for Security
JWT_SECRET=super_secret_synapse_jwt_key_9988
JWT_EXPIRES_IN=7d

# Vector Database Settings (Falls back to in-memory Mock DB)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX=synapse-agents

# Cloudinary Assets Storage (Falls back to local mock server assets)
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# Payments Integrations (Stripe & Razorpay - simulated checkout defaults)
STRIPE_SECRET_KEY=sk_test_51...
STRIPE_WEBHOOK_SECRET=whsec_...
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=rzp_secret_...

# FastAPI ML Service Configuration
ML_SERVICE_URL=http://localhost:8000
